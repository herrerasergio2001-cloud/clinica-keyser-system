NODE_ENV=production
POSTGRES_DB=clinic_keyser
POSTGRES_USER=clinic
POSTGRES_PASSWORD=replace-with-a-strong-url-safe-password
DATABASE_URL=postgresql://clinic:replace-with-a-strong-url-safe-password@postgres:5432/clinic_keyser?schema=public
JWT_ACCESS_SECRET=replace-with-a-long-random-access-secret
JWT_REFRESH_SECRET=replace-with-a-different-long-random-refresh-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
API_PORT=3001
API_HOST=0.0.0.0
WEB_PORT=3000
CORS_ORIGIN=https://clinicakeyser.com
AUTH_COOKIE_DOMAIN=.clinicakeyser.com
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_NAME=
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=
SEED_ADMIN_NAME=
SEED_ADMIN_SPECIALTY=
SEED_ADMIN_MINSA_CODE=
SEED_ADMIN_PHONE=
NEXT_PUBLIC_API_URL=https://api.clinicakeyser.com
LOCAL_STORAGE_ROOT=/app/storage
PDF_HEADER_NAME=Clinica Keyser
THERMAL_PRINTER_ENABLED=false
# Los datos clínicos, inventario y promociones de demostración permanecen
# desactivados por defecto. No habilitar en producción.
SEED_DEMO_DATA=false
