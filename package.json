{
  "name": "clinica-keyser-system",
  "private": true,
  "version": "0.1.0",
  "description": "Production-ready modular monolith ERP/EMR for Clinica Keyser.",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "concurrently -k \"npm run dev:api\" \"npm run dev:web\"",
    "dev:api": "npm run dev -w apps/api",
    "dev:web": "npm run dev -w apps/web",
    "build": "npm run build -w apps/api && npm run build -w apps/web",
    "test": "npm run test -w apps/api",
    "lint": "npm run lint -w apps/api && npm run lint -w apps/web",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "prisma:generate": "prisma generate --schema=./database/prisma/schema.prisma",
    "prisma:validate": "prisma validate --schema=./database/prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema=./database/prisma/schema.prisma",
    "prisma:deploy": "prisma migrate deploy --schema=./database/prisma/schema.prisma",
    "prisma:reset": "prisma migrate reset --schema=./database/prisma/schema.prisma --force",
    "seed": "node --import tsx database/seed/seed.ts"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "prisma": "^5.22.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
